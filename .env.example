# Supabase — https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Gemini — https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=AIza...

# Auth (server-side only — no VITE_ prefix, never bundled into client JS)
# AUTH_PASSWORD = the password users type to access the site
# AUTH_SECRET   = a random token stored in the cookie (generate with: openssl rand -hex 32)
AUTH_PASSWORD=your-password-here
AUTH_SECRET=generate-with-openssl-rand-hex-32
